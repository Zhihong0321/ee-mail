# Resend API Configuration
RESEND_API_KEY=re_your_api_key_here

# Email Domains (single or multiple comma-separated)
# Single domain:
EMAIL_DOMAIN=eternalgy.me
DEFAULT_FROM=noreply@eternalgy.me

# Multiple domains (uncomment to use):
# EMAIL_DOMAINS=eternalgy.me,anotherdomain.com,thirddomain.org
# DEFAULT_SENDERS=eternalgy.me:noreply@eternalgy.me,anotherdomain.com:noreply@anotherdomain.com,thirddomain.org:admin@thirddomain.org

# Server Configuration
PORT=3000
NODE_ENV=production

# Webhook Secret (optional - for verifying incoming webhooks)
WEBHOOK_SECRET=your_webhook_secret_here

# PostgreSQL Database (Railway provides this automatically)
DATABASE_URL=postgresql://username:password@host:port/database

# SEDA ATAP approval task worker
SEDA_API_KEY=your_seda_api_key_here
SEDA_STATUS_API_URL=https://admin.atap.solar/api/v1/seda/status
# Keep false in production. true performs matching without updating SEDA.
SEDA_STATUS_DRY_RUN=false
SEDA_TASK_WORKER_INTERVAL_MS=5000

# Railway will set these automatically:
# RAILWAY_STATIC_URL
# RAILWAY_PROJECT_NAME
# RAILWAY_SERVICE_NAME
